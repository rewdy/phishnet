# iCloud IMAP
IMAP_HOST=imap.mail.me.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=
IMAP_PASSWORD=
INBOX_MAILBOX=INBOX
JUNK_MAILBOX=Junk

# Model provider
# openai = OpenAI API, ollama = local Ollama server
MODEL_PROVIDER=openai
# light = sexual only, balanced = sexual + spam, strict = sexual + spam + annoyances
FILTER_PROFILE=light

# OpenAI (used when MODEL_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Ollama (used when MODEL_PROVIDER=ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# Runtime behavior
POLL_INTERVAL_MINUTES=15
CONFIDENCE_THRESHOLD=0.6
MAX_MESSAGES_PER_RUN=100
DRY_RUN=true

# Network exposure for local API/UI stack
# false (default): bind API/UI to localhost only (127.0.0.1)
# true: bind API/UI to all interfaces (0.0.0.0) for LAN access
LAN_MODE=false
# Optional overrides (used when LAN_MODE=false unless explicitly set)
PHISHNET_API_HOST=127.0.0.1
PHISHNET_API_PORT=8787
PHISHNET_UI_HOST=127.0.0.1
PHISHNET_UI_PORT=54321
# Optional comma-separated hostnames for Vite dev server host allowlist
# (for `bun run dev`; runtime static server does not use this).
# Example: macmini.internal,phishnet.local
PHISHNET_UI_ALLOWED_HOSTS=

# Storage + reliability
SQLITE_PATH=./data/email-filter.db
MAX_CLASSIFICATION_FAILURES=3
LOG_RETENTION_DAYS=90

# Comma-separated regex patterns matched against sender + subject.
# Example: noreply@example.com,.*@trusted-domain\\.com
ALLOWLIST_REGEX=
